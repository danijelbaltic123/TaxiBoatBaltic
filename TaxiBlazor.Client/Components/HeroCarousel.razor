@using System.Timers
@using TaxiBlazor.Shared.Services
@inject IJSRuntime JS
@inject PauseCarouselService CarouselService
@implements IAsyncDisposable

<div class="carousel">
    @if (Cards.Count > 0)
    {
        @foreach (var card in Cards.Select((x, i) => new { x, i }))
        {
            var cls = GetItemClass(card.i);
            <div class="@cls" aria-hidden="@(card.i != currentIndex && card.i != nextIndex)">
                <img src="@card.x.ImageUrl"
                     alt="@card.x.Title"
                     class="carousel-image" />

                <div class="carousel-overlay">
                    <h2 class="carousel-title top">
                        @card.x.Title
                    </h2>

                    <div class="separator"></div>

                    <p class="carousel-title bottom">
                        @card.x.Description
                    </p>
                </div>
            </div>
        }
    }

    <button class="nav-button left" @onclick="PreviousCards">&#10094;</button>
    <button class="nav-button right" @onclick="NextCards">&#10095;</button>

    <div class="carousel-dots">
        @for (int i = 0; i < Cards.Count; i++)
        {
            int dotIndex = i;
            <span class="dot @(currentIndex == dotIndex ? "active" : "")"
                  @onclick="() => SetSlide(dotIndex)"></span>
        }
    </div>
</div>

@code {
    private List<Card> Cards = new();
    private int currentIndex = 0;
    private int nextIndex = -1;
    private int prevIndex = -1;
    private Timer? timer;
    private bool isAnimating;
    private bool _disposed;

    // timings (ms) - tune as needed
    private readonly int enterMs = 900;
    private readonly int showMs = 3200;
    private readonly int exitMs = 900;

    protected override async Task OnInitializedAsync()
    {
        CarouselService.OnPauseChanged += HandlePauseChanged;
        Cards = await LoadCards();
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender)
            return;

        timer = new Timer(6500);
        timer.Elapsed += async (_, _) =>
        {
            if (_disposed) return;
            if (CarouselService.IsPaused) return;
            await InvokeAsync(async () => await AnimateTransition(1));
        };
        timer.Start();
    }

    private string GetItemClass(int idx)
    {
        // base class
        var cl = "carousel-item";
        if (!isAnimating && idx == currentIndex) return $"{cl} active show";
        if (isAnimating)
        {
            if (idx == nextIndex) return $"{cl} entering";
            if (idx == prevIndex) return $"{cl} exiting";
            if (idx == currentIndex && nextIndex == -1) return $"{cl} active show";
        }
        if (idx == currentIndex) return $"{cl} active show";
        return cl;
    }

    private async Task AnimateTransition(int direction)
    {
        if (isAnimating) return;
        if (Cards.Count <= 1) return;

        isAnimating = true;
        prevIndex = currentIndex;
        nextIndex = (currentIndex + direction + Cards.Count) % Cards.Count;

        // start enter animation for next slide while prev is visible
        StateHasChanged();
        await Task.Delay(enterMs); // next grows and centers, texts appear

        // keep show for a while
        await Task.Delay(showMs);

        // start exit: prev slides right & shrinks, next stays centered
        StateHasChanged();
        await Task.Delay(exitMs);

        // finalize indices
        currentIndex = nextIndex;
        nextIndex = -1;
        prevIndex = -1;
        isAnimating = false;
        StateHasChanged();
    }

    private async Task NextCards() => await AnimateTransition(1);
    private async Task PreviousCards() => await AnimateTransition(-1);

    private async Task SetSlide(int index)
    {
        if (index == currentIndex) return;
        if (isAnimating) return;
        await AnimateTransition(index > currentIndex ? 1 : -1);
    }

    private void HandlePauseChanged(bool paused)
    {
        if (paused) timer?.Stop();
        else timer?.Start();
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        CarouselService.OnPauseChanged -= HandlePauseChanged;
        timer?.Stop();
        timer?.Dispose();
        await Task.CompletedTask;
    }

    private async Task<List<Card>> LoadCards()
    {
        int width = 1200;
        try { width = await JS.InvokeAsync<int>("getWindowWidth"); } catch { }
        bool mobile = width < 800;

        return new List<Card>
        {
            new("Speed Boat Services","Exclusive speed boat transfers across the Adriatic coast.",
                mobile ? "images/SpeedBoatServiceMobile.svg" : "images/SpeedBoatService.svg"),
            new("Rent a Boat","Discover hidden beaches and islands at your own pace.",
                mobile ? "images/RentABoatMobile.svg" : "images/RentABoat.svg"),
            new("All Day Tours","Spend the entire day exploring breathtaking destinations.",
                mobile ? "images/AllDayToursMobile.svg" : "images/AllDayTours.svg"),
            new("Half Day Tours","Perfect short adventures for unforgettable memories.",
                mobile ? "images/HalfDayToursMobile.svg" : "images/HalfDayTours.svg"),
            new("Scooter Rentals","Explore Šibenik quickly and easily.",
                mobile ? "images/RentAScooterMobile.svg" : "images/RentAScooter.svg")
        };
    }

    public record Card(string Title, string Description, string ImageUrl);
}