@inherits BookingFormBase
@inject IJSRuntime JS

<div>
	@if (IsVisible)
	{
		<div class="popup-backdrop" @onclick="OnBackdropClick">
			<div class="popup" @onclick:stopPropagation>
				<div class="popup-header">
					<h2>Book our service here</h2>
					<button class="close-btn" @onclick="Hide">✖</button>
				</div>
				<div class="tour-tabs">
					<button class="tour-tab @(activeTab == 0 ? "active" : "")" @onclick="() => SetTab(0)">Speed Boat Service</button>
					<button class="tour-tab @(activeTab == 1 ? "active" : "")" @onclick="() => SetTab(1)">Private Boat Tour</button>
					<button class="tour-tab @(activeTab == 2 ? "active" : "")" @onclick="() => SetTab(2)">Rent a Boat</button>
					<button class="tour-tab @(activeTab == 3 ? "active" : "")" @onclick="() => SetTab(3)">Rent a Scooter</button>
				</div>
				<EditForm Model="@booking" OnValidSubmit="SubmitBooking" OnInvalidSubmit="OnInvalidSubmit">
					<DataAnnotationsValidator />
					<div class="popup-body">
						<div class="form-section fade-in">
							<label class="form-label">

								@if (activeTab == 0)
								{
									<label class="form-label">Select Transfer:</label>
									<select @bind="booking.SelectedOption" class="form-control">
										<option value="">-- Select Transfer --</option>
										@foreach (var speedboat in Transfers)
										{
											<option value="@speedboat">@speedboat</option>
										}
									</select>
								}
								else if
								(activeTab == 1)
								{
									<label>Select Tour:</label>
									<select @bind="booking.SelectedOption" class="form-control">
										<option value="">-- Select Tour --</option>
										@foreach (var tour in Tours)
										{
											<option value="@tour">@tour</option>
										}
									</select>
								}
								else if (activeTab == 2)
								{
									<label>Select Boat:</label>
									<select @bind="booking.SelectedOption" class="form-control">
										<option value="">-- Select Boat --</option>
										@foreach (var boat in Boats)
										{
											<option value="@boat">@boat</option>
										}
									</select>
								}
								else if (activeTab == 3)
								{
									<label>Select Scooter:</label>
									<select @bind="booking.SelectedOption" class="form-control">
										<option value="">-- Select Scooter --</option>
										@foreach (var scooter in Scooters)
										{
											<option value="@scooter">@scooter</option>
										}
									</select>
								}
								<ValidationMessage For="@(() => booking.SelectedOption)" />
							</label>
						</div>
						<div class="popup-grid">
							<div>
								<label>Full Name</label>
								<input type="text" @bind="booking.FullName" class="form-control" placeholder="John Doe" />
								<ValidationMessage For="@(() => booking.FullName)" />
							</div>
							<div>
								<label>Email</label>
								<input type="email" @bind="booking.Email" class="form-control" placeholder="example@mail.com" />
								<ValidationMessage For="@(() => booking.Email)" />
							</div>
							<div>
								<label>Date</label>
								<input type="date" @bind="booking.Date" class="form-control" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
								<ValidationMessage For="@(() => booking.Date)" />
							</div>
							<div>
								<label>Departure Time</label>
								<input type="time" @bind="booking.DepartureTime" class="form-control" />
								<ValidationMessage For="@(() => booking.DepartureTime)" />
							</div>
							<div>
								<label>People</label>
								<input type="number" min="1" max="@MaxPeople" @bind="booking.NumberOfPeople" class="form-control" />
								<ValidationMessage For="@(() => booking.NumberOfPeople)" />
							</div>
						</div>

						<div class="notes-section">
							<label>Notes</label>
							<textarea @bind="booking.Notes" class="form-control" placeholder="Add any special requests..."></textarea>
						</div>
					</div>
					<footer class="modal-footer">

						<button class="submit-btn" type="submit">Submit</button>
						<div class="toast-massage">
							@if (ShowSuccess)
							{
								<div class="toast-success">
									✅ Booking submitted successfully!
								</div>
							}
							@if (ShowError)
							{
								<div class="toast-error">
									⚠️ Please check the form and try again.
								</div>
							}
						</div>
						<div>
							@if (IsSending)
							{
								<div class="spinner"></div>
							}
							@if (!string.IsNullOrEmpty(Status))
							{
								<div class="status-message">@Status</div>
							}
						</div>
					</footer>
				</EditForm>
			</div>
		</div>
	}
</div>