@inject IJSRuntime JS

@if (!consentGiven)
{
    <div class="cookie-banner">
        <p>
            We use cookies to improve your experience. You can accept all, reject non-essential,
            or manage preferences. Read more in our <a href="/privacy">Privacy Policy</a>.
        </p>
        <div class="cookie-actions">
            <button class="btn accept" @onclick="AcceptAll">Accept All</button>
            <button class="btn reject" @onclick="RejectAll">Reject</button>
            <button class="btn manage" @onclick="()=>showPreferences=true">Manage Preferences</button>
        </div>
    </div>
}

@if (showPreferences)
{
    <div class="cookie-modal">
        <div class="cookie-modal-content">
            <h3>Manage Cookie Preferences</h3>
            <label>
                <input type="checkbox" checked disabled /> Necessary (always enabled)
            </label>
            <label>
                <input type="checkbox" @bind="analytics" /> Analytics
            </label>
            <label>
                <input type="checkbox" @bind="marketing" /> Marketing
            </label>
            <div class="cookie-actions">
                <button class="btn save" @onclick="SavePreferences">Save Preferences</button>
                <button class="btn cancel" @onclick="()=>showPreferences=false">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private bool consentGiven = false;
    private bool showPreferences = false;
    private bool analytics = false;
    private bool marketing = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var consent = await JS.InvokeAsync<string>("localStorage.getItem", "cookieConsent");
            if (!string.IsNullOrEmpty(consent))
            {
                consentGiven = true;
                var analyticsPref = await JS.InvokeAsync<string>("localStorage.getItem", "cookieAnalytics");
                var marketingPref = await JS.InvokeAsync<string>("localStorage.getItem", "cookieMarketing");

                analytics = analyticsPref == "true";
                marketing = marketingPref == "true";
            }
            StateHasChanged();
        }
    }

    private async Task AcceptAll()
    {
        await JS.InvokeVoidAsync("localStorage.setItem", "cookieConsent", "accepted");
        await JS.InvokeVoidAsync("localStorage.setItem", "cookieAnalytics", "true");
        await JS.InvokeVoidAsync("localStorage.setItem", "cookieMarketing", "true");
        consentGiven = true;
    }

    private async Task RejectAll()
    {
        await JS.InvokeVoidAsync("localStorage.setItem", "cookieConsent", "rejected");
        await JS.InvokeVoidAsync("localStorage.setItem", "cookieAnalytics", "false");
        await JS.InvokeVoidAsync("localStorage.setItem", "cookieMarketing", "false");
        consentGiven = true;
    }

    private async Task SavePreferences()
    {
        await JS.InvokeVoidAsync("localStorage.setItem", "cookieConsent", "custom");
        await JS.InvokeVoidAsync("localStorage.setItem", "cookieAnalytics", analytics.ToString().ToLower());
        await JS.InvokeVoidAsync("localStorage.setItem", "cookieMarketing", marketing.ToString().ToLower());
        consentGiven = true;
        showPreferences = false;
    }
}
